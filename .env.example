# -------------------------------------------------------
# Datenbank
# Lokal:  postgresql://workmate:workmate@localhost:5432/workmate_access
# Docker: wird automatisch durch docker-compose überschrieben
# -------------------------------------------------------
DATABASE_URL=postgresql://workmate:workmate@localhost:5432/workmate_access

PROJEKT_NAME=Workmate Access
LOG_LEVEL=INFO

# -------------------------------------------------------
# Keycloak (OIDC)
# -------------------------------------------------------
KEYCLOAK_URL=https://login.intern.phudevelopement.xyz
KEYCLOAK_CLIENT_ID=workmate-backend
KEYCLOAK_CLIENT_SECRET=your_client_secret
KEYCLOAK_REALM=kit

# -------------------------------------------------------
# CORS
# -------------------------------------------------------
CORS_ORIGINS=["https://access.intern.phudevelopement.xyz","http://localhost:8000"]

# -------------------------------------------------------
# Zugangskontrolle
# -------------------------------------------------------
DEFAULT_LOCK_TIMEOUT=5
MAX_FAILED_ATTEMPTS=3
LOCKOUT_DURATION=300

# -------------------------------------------------------
# sent.dm (OTP via WhatsApp / SMS)
# -------------------------------------------------------
SENT_DM_API_KEY=your_sentdm_api_key
SENT_DM_CUSTOMER_ID=your_sentdm_customer_id
SENT_DM_OTP_TEMPLATE_ID=otp
SENT_DM_SANDBOX=false

# OTP Rate-Limiting
OTP_SEND_MAX_PER_HOUR=5
OTP_VERIFY_MAX_ATTEMPTS=10
OTP_VERIFY_WINDOW_MINUTES=15

# -------------------------------------------------------
# Yubico OTP (YubiCloud)
# API-Key beantragen: https://upgrade.yubico.com/getapikey/
# -------------------------------------------------------
YUBICO_CLIENT_ID=
YUBICO_SECRET_KEY=
