# Database
DATABASE_URL=postgresql://workmate:workmate@localhost:5432/workmate_access
PROJEKT_NAME=Workmate Access

# Keycloak
KEYCLOAK_URL=https://login.intern.phudevelopement.xyz
KEYCLOAK_CLIENT_ID=workmate-backend
KEYCLOAK_CLIENT_SECRET=your_client_secret
KEYCLOAK_REALM=kit

# API
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Access Control
DEFAULT_LOCK_TIMEOUT=5
MAX_FAILED_ATTEMPTS=3
LOCKOUT_DURATION=300

# sent.dm OTP (WhatsApp/SMS)
SENT_DM_API_KEY=your_sentdm_api_key
SENT_DM_CUSTOMER_ID=your_sentdm_customer_id
SENT_DM_OTP_TEMPLATE_ID=otp

# Logging
LOG_LEVEL=INFO
